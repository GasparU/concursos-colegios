    {
      "id": "geo_paralelas_angulos_ecuaciones_01",
      "tema": "geometria",
      "subtipo": "paralelas_angulos_ecuaciones",
      "grado": "6to",
      "etapa": ["final"],
      "dificultad": ["avanzado"],
      "bidireccional": true,
      "enunciado": "En la figura, L1 y L2 son rectas paralelas. Si el ángulo α mide {a}x + {b}° y el ángulo β mide {c}x + {d}°, halla el valor de x.",
      "variables": {
        "a": { "type": "number", "min": 2, "max": 5, "step": 1 },
        "b": { "type": "number", "min": 0, "max": 20, "step": 1 },
        "c": { "type": "number", "min": 2, "max": 5, "step": 1 },
        "d": { "type": "number", "min": 0, "max": 20, "step": 1 }
      },
      "relaciones": ["x = (d - b) / (a - c)"],
      "restricciones": ["a != c", "x > 0", "a*x + b > 0", "c*x + d > 0"],
      "incognita_directa": "x",
      "incognitas_inversa": ["a", "b", "c", "d"],
      "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
      "metadata": {
        "habilidades": ["ángulos entre paralelas", "ecuaciones"],
        "tiempo_estimado": 150,
        "requiere_calculadora": true,
        "fuente": "Adaptado de problema 18 (6to clasificatoria)"
      }
    },
    {
