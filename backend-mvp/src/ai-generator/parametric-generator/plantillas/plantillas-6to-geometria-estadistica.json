{
  "id": "geo_cubo_agua_01",
  "tema": "geometria",
  "subtipo": "cubo_agua",
  "grado": "6to",
  "etapa": ["final"],
  "dificultad": ["intermedio"],
  "bidireccional": true,
  "enunciado": "Un recipiente cúbico de volumen {volumen_total} contiene agua hasta cierta altura. Si el volumen de agua es {volumen_agua}, calcula la altura del agua.",
  "variables": {
    "volumen_total": { "type": "number", "min": 8, "max": 64, "step": 1 },
    "volumen_agua": { "type": "number", "min": 1, "max": "{volumen_total-1}", "step": 1 }
  },
  "relaciones": [
    "arista = volumen_total^(1/3)",
    "altura = volumen_agua / (arista^2)"
  ],
  "restricciones": [
    "volumen_agua < volumen_total"
  ],
  "incognita_directa": "altura",
  "incognitas_inversa": ["volumen_total", "volumen_agua"],
  "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
  "metadata": {
