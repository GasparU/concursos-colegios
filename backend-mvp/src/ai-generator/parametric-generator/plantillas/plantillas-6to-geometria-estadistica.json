    {
      "id": "geo_area_terreno_compuesto_01",
      "tema": "geometria",
      "subtipo": "area_terreno_compuesto",
      "grado": "6to",
      "etapa": ["final"],
      "dificultad": ["avanzado"],
      "bidireccional": true,
      "enunciado": "Un terreno está formado por un rectángulo y cuatro triángulos rectángulos. Las dimensiones del rectángulo son {largo} m y {ancho} m, y los triángulos tienen catetos de {cateto1} m y {cateto2} m. Calcula el área total del terreno.",
      "variables": {
        "largo": { "type": "number", "min": 5, "max": 20, "step": 1 },
        "ancho": { "type": "number", "min": 3, "max": 15, "step": 1 },
        "cateto1": { "type": "number", "min": 2, "max": 8, "step": 1 },
        "cateto2": { "type": "number", "min": 2, "max": 8, "step": 1 }
      },
      "relaciones": [
        "area_rect = largo * ancho",
        "area_tri = (cateto1 * cateto2) / 2",
        "area_total = area_rect + 4 * area_tri"
      ],
      "restricciones": ["cateto1 <= largo/2", "cateto2 <= ancho/2"],
      "incognita_directa": "area_total",
      "incognitas_inversa": ["largo", "ancho", "cateto1", "cateto2"],
      "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
