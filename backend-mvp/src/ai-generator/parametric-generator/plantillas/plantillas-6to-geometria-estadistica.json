      "restricciones": ["lado_base < arista_cubo"],
      "incognita_directa": "altura_prisma",
      "incognitas_inversa": ["arista_cubo", "lado_base"],
      "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
