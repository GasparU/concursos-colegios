{
  "id": "geo_triangulo_cuadrado_inscrito_01",
  "tema": "geometria",
  "subtipo": "triangulo_cuadrado_inscrito",
  "grado": "5to",
  "etapa": ["final"],
  "dificultad": ["avanzado"],
  "bidireccional": true,
  "enunciado": "En un triángulo ABC, se inscribe un cuadrado PQRS de modo que el lado PQ está sobre la base AC. Si el área del triángulo ABC es {area_triangulo} m² y la altura del triángulo es {altura} m, calcula el área del cuadrado.",
  "variables": {
    "area_triangulo": { "type": "number", "min": 18, "max": 50, "step": 2 },
    "altura": { "type": "number", "min": 6, "max": 15, "step": 1 }
  },
  "relaciones": [
    "base = 2 * area_triangulo / altura",
    "lado_cuadrado = (base * altura) / (base + altura)",
    "area_cuadrado = lado_cuadrado * lado_cuadrado"
  ],
  "restricciones": [
    "lado_cuadrado > 0",
    "lado_cuadrado < altura",
    "lado_cuadrado < base"
  ],
  "incognita_directa": "area_cuadrado",
  "incognitas_inversa": ["area_triangulo", "altura"],
  "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
  "metadata": {
    "habilidades": ["área de triángulo", "cuadrado inscrito", "semejanza"],
    "tiempo_estimado": 200,
    "requiere_calculadora": true,
    "fuente": "Adaptado de problema 19 (clasificatoria)"
  }
}






