    {
      "id": "geo_cuadrados_superpuestos_perimetro_01",
      "tema": "geometria",
      "subtipo": "cuadrados_superpuestos_perimetro",
      "grado": "6to",
      "etapa": ["final"],
      "dificultad": ["avanzado"],
      "bidireccional": true,
      "enunciado": "La suma de los perímetros de los cuadrados ABCD y QDMN es {suma_perimetros}. El área de la región sombreada es {area_sombreada}. Calcula el lado del cuadrado mayor.",
      "variables": {
        "suma_perimetros": {
          "type": "number",
          "min": 40,
          "max": 100,
          "step": 5
        },
        "area_sombreada": { "type": "number", "min": 20, "max": 60, "step": 5 }
      },
      "relaciones": [
        "lado_mayor = (suma_perimetros / 4 + sqrt((suma_perimetros/4)^2 - 8*area_sombreada)) / 2"
      ],
      "restricciones": ["(suma_perimetros/4)^2 - 8*area_sombreada >= 0"],
      "incognita_directa": "lado_mayor",
      "incognitas_inversa": ["suma_perimetros", "area_sombreada"],
      "formato_respuesta": { "tipo": "decimal", "decimales": 2 },
      "metadata": {
        "habilidades": [
          "perímetro de cuadrado",
          "área",
          "ecuaciones cuadráticas"
        ],
        "tiempo_estimado": 200,
        "requiere_calculadora": true,
        "fuente": "Adaptado de problema 16 (6to final)"
      }
